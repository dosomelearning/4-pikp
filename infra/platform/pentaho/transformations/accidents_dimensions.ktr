  <step>
    <name>Build Dim Time Fields</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>Y</compatible>
    <optimizationLevel/>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>ScriptValue</jsScript_name>
        <jsScript_script><![CDATA[var dt = null;
var time_key = 0;
var date_value = null;
var year_num = 0;
var month_num = 0;
var day_num = 0;
var hour_num = 0;
var day_of_week_num = 0;
var day_of_week_name = "";
var is_weekend = false;

if (event_ts != null) {
  if (event_ts instanceof java.util.Date) {
    dt = event_ts;
  } else {
    var s = String(event_ts);
    if (s != null && s.length > 0) {
      var patterns = [
        "yyyy-MM-dd HH:mm:ss",
        "yyyy/MM/dd HH:mm:ss",
        "yyyy-MM-dd HH:mm:ss.SSS",
        "yyyy/MM/dd HH:mm:ss.SSS"
      ];
      for (var i = 0; i < patterns.length; i++) {
        try {
          var parser = new java.text.SimpleDateFormat(patterns[i]);
          parser.setLenient(false);
          dt = parser.parse(s);
          break;
        } catch (e) {
          // try next pattern
        }
      }
    }
  }
}

if (dt != null) {
  var dateFmt = new java.text.SimpleDateFormat("yyyy-MM-dd");
  var dowFmt = new java.text.SimpleDateFormat("EEEE");

  date_value = dateFmt.parse(dateFmt.format(dt));
  day_of_week_name = dowFmt.format(dt);

  var cal = java.util.Calendar.getInstance();
  cal.setTime(dt);
  year_num = cal.get(java.util.Calendar.YEAR);
  month_num = cal.get(java.util.Calendar.MONTH) + 1;
  day_num = cal.get(java.util.Calendar.DAY_OF_MONTH);
  hour_num = cal.get(java.util.Calendar.HOUR_OF_DAY);
  time_key = (year_num * 1000000) + (month_num * 10000) + (day_num * 100) + hour_num;

  // Java DOW: 1=Sunday..7=Saturday -> model DOW: 0=Sunday..6=Saturday
  day_of_week_num = cal.get(java.util.Calendar.DAY_OF_WEEK) - 1;
  is_weekend = (day_of_week_num == 0 || day_of_week_num == 6);
}]]></jsScript_script>
      </jsScript>
    </jsScripts>
